@model PennyWise.ViewModels.TransactionViewModel

@{
    ViewData["Title"] = "İşlemi Düzenle";
}

<div class="row justify-content-center">
    <div class="col-md-6 col-lg-5">
        <div class="card shadow-sm">
            <div class="card-header py-3 bg-transparent">
                <div class="d-flex align-items-center gap-2">
                    <i class="fa-solid fa-pen-to-square text-primary fa-lg"></i>
                    <h5 class="mb-0 fw-bold">İşlem Detaylarını Düzenle</h5>
                </div>
            </div>
            <div class="card-body">
                <p class="text-muted small mb-4">Mevcut gelir veya gider işleminizin detaylarını güncelleyin.</p>

                <form asp-action="Edit" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3" role="alert"></div>
                    <input type="hidden" asp-for="Id" />

                    <!-- Kategori Seçimi -->
                    <div class="mb-3">
                        <label asp-for="CategoryId" class="form-label text-dark fw-semibold">Grup / Kategori</label>
                        <select asp-for="CategoryId" class="form-select" asp-items="ViewBag.Categories">
                            <option value="">-- Kategori Seçin --</option>
                        </select>
                        <span asp-validation-for="CategoryId" class="text-danger small"></span>
                    </div>

                    <!-- Tutar ve Tarih -->
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label asp-for="Amount" class="form-label text-dark fw-semibold">Tutar</label>
                            <div class="input-group">
                                <input asp-for="Amount" type="number" step="0.01" class="form-control" placeholder="0.00" required />
                                <span class="input-group-text bg-light border-start-0">₺</span>
                            </div>
                            <span asp-validation-for="Amount" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Date" class="form-label text-dark fw-semibold">İşlem Tarihi</label>
                            <input asp-for="Date" class="form-control" type="date" value="@Model.Date.ToString("yyyy-MM-dd")" required />
                            <span asp-validation-for="Date" class="text-danger small"></span>
                        </div>
                    </div>

                    <!-- Açıklama -->
                    <div class="mb-4">
                        <label asp-for="Description" class="form-label text-dark fw-semibold">Açıklama (Referans No / Detay)</label>
                        <textarea asp-for="Description" class="form-control" rows="3" placeholder="Ödemenin detaylarını, faturasını veya referansını yazın..."></textarea>
                        <span asp-validation-for="Description" class="text-danger small"></span>
                    </div>

                    <!-- Butonlar -->
                    <div class="d-flex gap-2 justify-content-end border-top pt-3">
                        <a asp-action="Index" class="btn btn-outline-primary px-3">İptal</a>
                        <button type="submit" class="btn btn-primary px-4 fw-semibold">
                            <i class="fa-solid fa-floppy-disk"></i> Değişiklikleri Kaydet
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
