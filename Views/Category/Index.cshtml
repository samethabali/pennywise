@model IEnumerable<PennyWise.Models.Category>

@{
    ViewData["Title"] = "Kategoriler";
}

<div class="container mt-4">
    <h2>Kategoriler</h2>
    <p>
        <a asp-action="Create" class="btn btn-primary">Yeni Kategori Ekle</a>
    </p>
    <table class="table">
        <thead>
            <tr>
                <th>Adı</th>
                <th>Tipi</th>
                <th style="width: 180px;">İşlemler</th>
            </tr>
        </thead>
        <tbody>
    @foreach (var item in Model) {
            <tr>
                <td>@item.Name</td>
                <td>@(item.Type == PennyWise.Models.TransactionType.Income ? "Gelir" : "Gider")</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning me-1">Düzenle</a>
                    <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline" onsubmit="return confirm('Bu kategoriyi silmek istediğinizden emin misiniz? Bu kategoriye ait tüm işlemler ve bütçeler silinecektir!');">
                        <button type="submit" class="btn btn-sm btn-outline-danger">Sil</button>
                    </form>
                </td>
            </tr>
    }
        </tbody>
    </table>
</div>
