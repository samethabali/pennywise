@model IEnumerable<PennyWise.Models.RecurringTransaction>
@using PennyWise.Models

@{
    ViewData["Title"] = "Düzenli Ödemeler";
    
    var activeCount = Model.Count(r => r.IsActive);
    var monthlyExpenses = Model.Where(r => r.IsActive && r.Category?.Type == TransactionType.Expense).Sum(r => r.Amount);
    var monthlyIncomes = Model.Where(r => r.IsActive && r.Category?.Type == TransactionType.Income).Sum(r => r.Amount);
}

<div class="container-fluid px-0">
    <!-- Üst Başlık ve Yeni Talimat Oluşturma -->
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4 pb-3 border-bottom gap-3">
        <div>
            <span class="text-muted text-uppercase fw-bold tracking-wider small" style="font-size: 0.75rem; letter-spacing: 0.05em;">Abonelik Planlayıcı</span>
            <h1 class="h2 mb-1">Ödeme Talimatlarım</h1>
            <p class="text-muted mb-0 small">Tekrarlayan periyodik harcama ve gelir işlemlerinizi buradan izleyin. Vade gününde otomatik yansır.</p>
        </div>
        <div>
            <a asp-action="Create" class="btn btn-primary">
                <i class="fa-solid fa-plus"></i> Yeni Talimat Tanımla
            </a>
        </div>
    </div>

    <!-- Abonelik Metrikleri -->
    <div class="row g-3 mb-4">
        <!-- Aktif Talimat Sayısı -->
        <div class="col-md-4">
            <div class="card p-3 border-start border-4 border-primary">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <div class="text-muted small fw-semibold uppercase tracking-wider mb-1" style="font-size: 0.75rem;">Aktif Talimat Adedi</div>
                        <div class="h3 mb-0 text-primary fw-bold">@activeCount Aktif</div>
                    </div>
                    <div class="p-2 bg-primary-subtle text-primary rounded-circle" style="width: 40px; height: 40px; display: flex; align-items: center; justify-content: center;">
                        <i class="fa-solid fa-rotate"></i>
                    </div>
                </div>
            </div>
        </div>

        <!-- Aylık Toplam Otomatik Gider -->
        <div class="col-md-4">
            <div class="card p-3 border-start border-4 border-danger">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <div class="text-muted small fw-semibold uppercase tracking-wider mb-1" style="font-size: 0.75rem;">Aylık Otomatik Gider</div>
                        <div class="h3 mb-0 text-danger fw-bold">@monthlyExpenses.ToString("C2")</div>
                    </div>
                    <div class="p-2 bg-danger-subtle text-danger rounded-circle" style="width: 40px; height: 40px; display: flex; align-items: center; justify-content: center;">
                        <i class="fa-solid fa-arrow-up-long"></i>
                    </div>
                </div>
            </div>
        </div>

        <!-- Aylık Toplam Otomatik Gelir -->
        <div class="col-md-4">
            <div class="card p-3 border-start border-4 border-success">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <div class="text-muted small fw-semibold uppercase tracking-wider mb-1" style="font-size: 0.75rem;">Aylık Otomatik Gelir</div>
                        <div class="h3 mb-0 text-success fw-bold">@monthlyIncomes.ToString("C2")</div>
                    </div>
                    <div class="p-2 bg-success-subtle text-success rounded-circle" style="width: 40px; height: 40px; display: flex; align-items: center; justify-content: center;">
                        <i class="fa-solid fa-arrow-down-long"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- İki Kolonlu Grid Düzeni -->
    <div class="row g-4">
        <!-- Sol Kolon: Aktif Ödeme Talimatları -->
        <div class="col-lg-8">
            <div class="card shadow-sm h-100">
                <div class="card-header py-3 bg-transparent d-flex justify-content-between align-items-center border-0">
                    <span class="fw-bold text-dark"><i class="fa-solid fa-play text-primary me-2"></i>Aktif Talimatlar</span>
                    <span class="badge bg-primary rounded-pill">@Model.Count(r => r.IsActive) Aktif</span>
                </div>
                <div class="card-body p-0">
                    @if (Model.Any(r => r.IsActive))
                    {
                        <div class="table-responsive">
                            <table class="table align-middle">
                                <thead>
                                    <tr>
                                        <th>Talimat Tanımı</th>
                                        <th>Kategori</th>
                                        <th>Periyot</th>
                                        <th>Tutar</th>
                                        <th>Valör Tarihi</th>
                                        <th class="text-end" style="width: 140px;">İşlemler</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in Model.Where(r => r.IsActive))
                                    {
                                        var isExpense = item.Category?.Type == TransactionType.Expense;
                                        <tr>
                                            <td class="fw-bold text-dark">@item.Description</td>
                                            <td><span class="badge bg-light text-dark border">@item.Category?.Name</span></td>
                                            <td>
                                                <span class="badge rounded-pill
                                                    @(item.RecurrenceType == RecurrenceType.Daily ? "bg-info bg-opacity-10 text-info border border-info border-opacity-20" :
                                                      item.RecurrenceType == RecurrenceType.Weekly ? "bg-warning bg-opacity-10 text-warning border border-warning border-opacity-20" :
                                                      item.RecurrenceType == RecurrenceType.Monthly ? "bg-primary bg-opacity-10 text-primary border border-primary border-opacity-20" : "bg-secondary bg-opacity-10 text-secondary border border-secondary border-opacity-20")">
                                                    @switch (item.RecurrenceType)
                                                    {
                                                        case RecurrenceType.Daily: @:Günlük
                                                            break;
                                                        case RecurrenceType.Weekly: @:Haftalık
                                                            break;
                                                        case RecurrenceType.Monthly: @:Aylık
                                                            break;
                                                        case RecurrenceType.Yearly: @:Yıllık
                                                            break;
                                                    }
                                                </span>
                                            </td>
                                            <td class="fw-bold @(isExpense ? "text-danger" : "text-success")">
                                                @(isExpense ? "-" : "+")@item.Amount.ToString("C2")
                                            </td>
                                            <td>
                                                @{
                                                    var daysLeft = (item.NextOccurrenceDate.Date - DateTime.UtcNow.Date).Days;
                                                }
                                                <div class="small text-muted mb-1">@item.NextOccurrenceDate.ToString("dd.MM.yyyy")</div>
                                                @if (daysLeft <= 0)
                                                {
                                                    <span class="badge bg-success bg-opacity-10 text-success small">Bugün</span>
                                                }
                                                else if (daysLeft <= 3)
                                                {
                                                    <span class="badge bg-warning bg-opacity-10 text-warning small">@daysLeft gün</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-light text-muted border small">@daysLeft gün</span>
                                                }
                                            </td>
                                            <td class="text-end">
                                                <div class="d-flex justify-content-end gap-1">
                                                    <form asp-action="ToggleActive" asp-route-id="@item.Id" method="post" class="d-inline">
                                                        <button type="submit" class="btn btn-sm btn-outline-warning py-1 px-2" title="Duraksat">
                                                            <i class="fa-solid fa-pause"></i>
                                                        </button>
                                                    </form>
                                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary py-1 px-2" title="Düzenle">
                                                        <i class="fa-solid fa-pen"></i>
                                                    </a>
                                                    <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline"
                                                          onsubmit="return confirm('Bu aboneliği silmek istediğinizden emin misiniz?');">
                                                        <button type="submit" class="btn btn-sm btn-outline-danger py-1 px-2" title="Sil">
                                                            <i class="fa-solid fa-trash-can"></i>
                                                        </button>
                                                    </form>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="text-center text-muted py-5 px-3">
                            <i class="fa-solid fa-rotate fa-4x text-muted mb-3 opacity-50"></i>
                            <h5 class="fw-bold text-dark">Aktif Talimat Yok</h5>
                            <p class="small text-muted mb-0">Henüz periyodik tekrarlanan bir para hareketi tanımlamadınız.</p>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Sağ Kolon: Durdurulmuş Talimatlar -->
        <div class="col-lg-4">
            <div class="card shadow-sm h-100">
                <div class="card-header py-3 bg-transparent d-flex justify-content-between align-items-center border-0">
                    <span class="fw-bold text-dark"><i class="fa-solid fa-pause text-warning me-2"></i>Durdurulanlar</span>
                    <span class="badge bg-warning text-dark rounded-pill">@Model.Count(r => !r.IsActive) Adet</span>
                </div>
                <div class="card-body p-0">
                    @if (Model.Any(r => !r.IsActive))
                    {
                        <div class="table-responsive">
                            <table class="table align-middle">
                                <thead>
                                    <tr>
                                        <th>Açıklama</th>
                                        <th class="text-end" style="width: 120px;">İşlemler</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in Model.Where(r => !r.IsActive))
                                    {
                                        <tr class="opacity-75">
                                            <td>
                                                <div class="fw-semibold text-muted text-decoration-line-through">@item.Description</div>
                                                <span class="small text-muted fw-bold">@item.Amount.ToString("C2")</span>
                                            </td>
                                            <td class="text-end">
                                                <div class="d-flex justify-content-end gap-1">
                                                    <form asp-action="ToggleActive" asp-route-id="@item.Id" method="post" class="d-inline">
                                                        <button type="submit" class="btn btn-sm btn-outline-success py-1 px-2" title="Yeniden Başlat">
                                                            <i class="fa-solid fa-play"></i>
                                                        </button>
                                                    </form>
                                                    <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline"
                                                          onsubmit="return confirm('Bu aboneliği kalıcı olarak silmek istiyor musunuz?');">
                                                        <button type="submit" class="btn btn-sm btn-outline-danger py-1 px-2" title="Sil">
                                                            <i class="fa-solid fa-trash-can"></i>
                                                        </button>
                                                    </form>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="text-center text-muted py-5 px-3">
                            <i class="fa-solid fa-circle-check fa-3x text-success mb-2 opacity-75"></i>
                            <h5 class="fw-bold text-dark">Durdurulan Kayıt Yok</h5>
                            <p class="small text-muted mb-0">Pasif durumda bekleyen ödeme talimatınız bulunmuyor.</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
