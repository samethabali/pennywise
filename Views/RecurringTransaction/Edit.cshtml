@model PennyWise.ViewModels.RecurringTransactionViewModel

@{
    ViewData["Title"] = "Aboneliği Düzenle";
}

<div class="row justify-content-center">
    <div class="col-md-7">
        <div class="card shadow-sm">
            <div class="card-header py-3 bg-transparent">
                <div class="d-flex align-items-center gap-2">
                    <i class="fa-solid fa-pen text-primary fa-lg"></i>
                    <h5 class="mb-0 fw-bold">Ödeme Talimatını Düzenle</h5>
                </div>
            </div>
            <div class="card-body">
                <p class="text-muted small mb-4">Mevcut düzenli ödeme talimatınızın tutar, açıklama ve periyot detaylarını güncelleyin.</p>

                <form asp-action="Edit" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3" role="alert"></div>
                    <input type="hidden" name="id" value="@ViewBag.RecurringId" />

                    <!-- Açıklama -->
                    <div class="mb-3">
                        <label asp-for="Description" class="form-label text-dark fw-semibold">Talimat / Abonelik Adı</label>
                        <input asp-for="Description" class="form-control" placeholder="Örn: Netflix, Spotify, Ev Kirası, Maaş" required />
                        <span asp-validation-for="Description" class="text-danger small"></span>
                    </div>

                    <!-- Tutar ve Periyot -->
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label asp-for="Amount" class="form-label text-dark fw-semibold">Tutar</label>
                            <div class="input-group">
                                <input asp-for="Amount" type="number" step="0.01" min="0.01" class="form-control" placeholder="0.00" required />
                                <span class="input-group-text bg-light border-start-0">₺</span>
                            </div>
                            <span asp-validation-for="Amount" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="RecurrenceType" class="form-label text-dark fw-semibold">Tekrarlama Periyodu</label>
                            <select asp-for="RecurrenceType" class="form-select">
                                <option value="0">Günlük</option>
                                <option value="1">Haftalık</option>
                                <option value="2">Aylık</option>
                                <option value="3">Yıllık</option>
                            </select>
                            <span asp-validation-for="RecurrenceType" class="text-danger small"></span>
                        </div>
                    </div>

                    <!-- Kategori -->
                    <div class="mb-3">
                        <label asp-for="CategoryId" class="form-label text-dark fw-semibold">Grup / Kategori</label>
                        <select asp-for="CategoryId" class="form-select" asp-items="ViewBag.Categories">
                            <option value="">-- Kategori Seçin --</option>
                        </select>
                        <span asp-validation-for="CategoryId" class="text-danger small"></span>
                    </div>

                    <!-- Başlangıç ve Bitiş Tarihi -->
                    <div class="row mb-4">
                        <div class="col-md-6">
                            <label asp-for="StartDate" class="form-label text-dark fw-semibold">İlk İşlem Tarihi (Başlangıç)</label>
                            <input asp-for="StartDate" class="form-control" type="date" required />
                            <span asp-validation-for="StartDate" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="EndDate" class="form-label text-dark fw-semibold">Bitiş Tarihi (İsteğe Bağlı)</label>
                            <input asp-for="EndDate" class="form-control" type="date" />
                            <div class="form-text text-muted" style="font-size: 0.75rem;">Boş bırakılırsa iptal edilene kadar sürer.</div>
                        </div>
                    </div>

                    <!-- Bilgi Notu -->
                    <div class="alert alert-info d-flex align-items-start gap-2 py-2 mb-4 border-info border-opacity-10" style="background-color: var(--info-bg); border-radius: 8px;">
                        <i class="fa-solid fa-circle-info mt-1 text-info"></i>
                        <small class="text-muted" style="font-size: 0.8rem;">
                            Talimat güncellendikten sonra sonraki ödeme vadeleri yeni ayarlara göre işlenecektir.
                        </small>
                    </div>

                    <div class="d-flex gap-2 justify-content-end border-top pt-3">
                        <a asp-action="Index" class="btn btn-outline-primary px-3">İptal</a>
                        <button type="submit" class="btn btn-primary px-4 fw-semibold">
                            <i class="fa-solid fa-floppy-disk"></i> Değişiklikleri Kaydet
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var amountInput = document.getElementById('Amount');
            if (amountInput) {
                amountInput.addEventListener('input', function () {
                    if (parseFloat(this.value) < 0) {
                        this.value = '';
                        this.setCustomValidity('Tutar negatif olamaz!');
                        this.reportValidity();
                    } else if (parseFloat(this.value) === 0) {
                        this.setCustomValidity('Tutar sıfır olamaz!');
                        this.reportValidity();
                    } else {
                        this.setCustomValidity('');
                    }
                });
                amountInput.addEventListener('keydown', function (e) {
                    if (e.key === '-' || e.key === 'e') {
                        e.preventDefault();
                    }
                });
            }
        });
    </script>
}
