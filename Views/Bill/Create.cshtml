@model PennyWise.Models.Bill

@{
    ViewData["Title"] = "Yeni Fatura Kaydet";
}

<div class="row justify-content-center">
    <div class="col-md-6 col-lg-5">
        <div class="card shadow-sm">
            <div class="card-header py-3 bg-transparent">
                <div class="d-flex align-items-center gap-2">
                    <i class="fa-solid fa-receipt text-primary fa-lg"></i>
                    <h5 class="mb-0 fw-bold">Yeni Fatura Ödeme Talimatı</h5>
                </div>
            </div>
            <div class="card-body">
                <p class="text-muted small mb-4">Gelecekte ödeyeceğiniz bir harcama veya periyodik fatura için takip ve hatırlatıcı tanımlayın.</p>

                <form asp-action="Create" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3" role="alert"></div>

                    <!-- Fatura Kategorisi Gizli Model Parametresi -->
                    <input type="hidden" asp-for="CategoryId" />

                    <!-- Başlık -->
                    <div class="mb-3">
                        <label asp-for="Title" class="form-label text-dark fw-semibold">Fatura / Kurum Adı</label>
                        <input asp-for="Title" class="form-control" placeholder="Örn: Elektrik Faturası, Türk Telekom, Kira" required />
                        <span asp-validation-for="Title" class="text-danger small"></span>
                    </div>

                    <!-- Tutar ve Vade Tarihi -->
                    <div class="row mb-4">
                        <div class="col-md-6">
                            <label asp-for="Amount" class="form-label text-dark fw-semibold">Tutar</label>
                            <div class="input-group">
                                <input asp-for="Amount" type="number" step="0.01" class="form-control" placeholder="0.00" required />
                                <span class="input-group-text bg-light border-start-0">₺</span>
                            </div>
                            <span asp-validation-for="Amount" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="DueDate" class="form-label text-dark fw-semibold">Son Ödeme Tarihi</label>
                            <input asp-for="DueDate" class="form-control" type="date" required />
                            <span asp-validation-for="DueDate" class="text-danger small"></span>
                        </div>
                    </div>

                    <!-- Butonlar -->
                    <div class="d-flex gap-2 justify-content-end border-top pt-3">
                        <a asp-action="Index" class="btn btn-outline-primary px-3">İptal</a>
                        <button type="submit" class="btn btn-primary px-4 fw-semibold">
                            <i class="fa-solid fa-check-double"></i> Faturayı Kaydet
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
