@model PennyWise.Models.SavingsGoal

@{
    ViewData["Title"] = "Hedef Güncelle";
}

<div class="container d-flex justify-content-center align-items-center" style="min-height: 80vh;">
    <div class="card p-4 shadow-sm" style="max-width: 500px; width: 100%;">
        <div class="card-header bg-transparent border-0 text-center mb-3">
            <h2 class="fw-bold mb-0">Hedef Güncelle</h2>
            <p class="text-muted small">Hedefin ismini veya miktarını güncelleyin.</p>
        </div>
        <div class="card-body p-0">
            <form asp-action="Edit" method="post">
                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="UserId" />
                <input type="hidden" asp-for="TargetDate" />
                <input type="hidden" asp-for="CurrentAmount" />

                <div class="mb-3">
                    <label asp-for="Title" class="form-label">Hedef Adı</label>
                    <input asp-for="Title" class="form-control" placeholder="Örn: Tatil, Araba" required />
                    <span asp-validation-for="Title" class="text-danger small"></span>
                </div>
                <div class="mb-4">
                    <label asp-for="TargetAmount" class="form-label">Hedef Miktar (₺)</label>
                    <input asp-for="TargetAmount" type="number" step="0.01" class="form-control" placeholder="Örn: 50000" required />
                    <span asp-validation-for="TargetAmount" class="text-danger small"></span>
                </div>
                <div class="d-grid gap-2">
                    <button type="submit" class="btn btn-primary fw-semibold py-2">Değişiklikleri Kaydet</button>
                    <a asp-action="Index" class="btn btn-outline-secondary fw-semibold py-2">İptal</a>
                </div>
            </form>
        </div>
    </div>
</div>
