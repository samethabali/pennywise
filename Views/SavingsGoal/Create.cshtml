@model PennyWise.Models.SavingsGoal

@{
    ViewData["Title"] = "Yeni Birikim Hedefi Ekle";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card p-4">
            <h2 class="mb-3">Yeni Birikim Hedefi Ekle</h2>
            <p class="text-muted small mb-4">Kendinize finansal hedefler koyarak birikim yapma motivasyonunuzu artırın.</p>

            <form asp-action="Create" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3" role="alert"></div>

                <div class="mb-3">
                    <label asp-for="Title" class="form-label"></label>
                    <input asp-for="Title" class="form-control" placeholder="Örn: Yeni Bilgisayar, Acil Durum Fonu, Yaz Tatili" />
                    <span asp-validation-for="Title" class="text-danger"></span>
                </div>

                <div class="row mb-3">
                    <div class="col-md-6">
                        <label asp-for="TargetAmount" class="form-label"></label>
                        <div class="input-group">
                            <input asp-for="TargetAmount" type="number" step="0.01" class="form-control" placeholder="0.00" />
                            <span class="input-group-text">₺</span>
                        </div>
                        <span asp-validation-for="TargetAmount" class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="CurrentAmount" class="form-label"></label>
                        <div class="input-group">
                            <input asp-for="CurrentAmount" type="number" step="0.01" class="form-control" placeholder="0.00" />
                            <span class="input-group-text">₺</span>
                        </div>
                        <span asp-validation-for="CurrentAmount" class="text-danger"></span>
                    </div>
                </div>

                <div class="mb-4">
                    <label asp-for="TargetDate" class="form-label"></label>
                    <input asp-for="TargetDate" class="form-control" type="date" />
                    <span asp-validation-for="TargetDate" class="text-danger"></span>
                </div>

                <div class="d-flex gap-3 justify-content-end">
                    <a asp-action="Index" class="btn btn-outline-primary">İptal</a>
                    <button type="submit" class="btn btn-primary fw-semibold">
                        <i class="fa-solid fa-bullseye me-2"></i>Hedefi Belirle
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
