@model PennyWise.Models.SavingsGoal

@{
    ViewData["Title"] = "Yeni Kasa Tanımla";
}

<div class="row justify-content-center">
    <div class="col-md-6 col-lg-5">
        <div class="card shadow-sm">
            <div class="card-header py-3 bg-transparent">
                <div class="d-flex align-items-center gap-2">
                    <i class="fa-solid fa-vault text-primary fa-lg"></i>
                    <h5 class="mb-0 fw-bold">Yeni Birikim Kasası Oluştur</h5>
                </div>
            </div>
            <div class="card-body">
                <p class="text-muted small mb-4">Gelecekteki hedefleriniz (ev, araba, tatil, teknoloji) için bir sanal kumbara tanımlayın ve birikime başlayın.</p>

                <form asp-action="Create" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3" role="alert"></div>

                    <!-- Kasa İsmi -->
                    <div class="mb-3">
                        <label asp-for="Title" class="form-label text-dark fw-semibold">Birikim Kasa Adı</label>
                        <input asp-for="Title" class="form-control" placeholder="Örn: Yeni Bilgisayar, Acil Durum Fonu, Seyahat" required />
                        <span asp-validation-for="Title" class="text-danger small"></span>
                    </div>

                    <!-- Hedef ve Başlangıç Birikimi -->
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label asp-for="TargetAmount" class="form-label text-dark fw-semibold">Hedeflenen Tutar</label>
                            <div class="input-group">
                                <input asp-for="TargetAmount" type="number" step="0.01" class="form-control" placeholder="0.00" required />
                                <span class="input-group-text bg-light border-start-0">₺</span>
                            </div>
                            <span asp-validation-for="TargetAmount" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="CurrentAmount" class="form-label text-dark fw-semibold">Başlangıç Birikimi</label>
                            <div class="input-group">
                                <input asp-for="CurrentAmount" type="number" step="0.01" class="form-control" placeholder="0.00" required />
                                <span class="input-group-text bg-light border-start-0">₺</span>
                            </div>
                            <span asp-validation-for="CurrentAmount" class="text-danger small"></span>
                        </div>
                    </div>

                    <!-- Vade Tarihi -->
                    <div class="mb-4">
                        <label asp-for="TargetDate" class="form-label text-dark fw-semibold">Hedef Vade Tarihi</label>
                        <input asp-for="TargetDate" class="form-control" type="date" required />
                        <span asp-validation-for="TargetDate" class="text-danger small"></span>
                    </div>

                    <!-- Butonlar -->
                    <div class="d-flex gap-2 justify-content-end border-top pt-3">
                        <a asp-action="Index" class="btn btn-outline-primary px-3">İptal</a>
                        <button type="submit" class="btn btn-primary px-4 fw-semibold">
                            <i class="fa-solid fa-floppy-disk"></i> Kasayı Oluştur
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
