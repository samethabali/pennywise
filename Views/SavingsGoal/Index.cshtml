@model IEnumerable<PennyWise.Models.SavingsGoal>

@{
    ViewData["Title"] = "Birikim Hedefleriniz";
}

<div class="container">
    <div class="d-flex justify-content-between align-items-center mb-4 pb-2 border-bottom">
        <div>
            <h1 class="h2 mb-0">Birikim Hedefleriniz</h1>
            <p class="text-muted mb-0">Hayalleriniz için biriktirdiğiniz bütçeleri planlayın ve hedefinize adım adım yaklaşın.</p>
        </div>
        <div>
            <a asp-action="Create" class="btn btn-primary fw-semibold">
                <i class="fa-solid fa-plus me-2"></i>Yeni Birikim Hedefi Ekle
            </a>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="fa-solid fa-circle-check me-2"></i>@TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="fa-solid fa-circle-exclamation me-2"></i>@TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="row g-4">
        @if (Model.Any())
        {
            @foreach (var goal in Model)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="card h-100 d-flex flex-column justify-content-between">
                        <div>
                            <div class="card-header d-flex justify-content-between align-items-start border-0 pb-0 bg-transparent pt-3 px-3">
                                <h5 class="fw-bold mb-0 text-main">@goal.Title</h5>
                                <form asp-action="Delete" asp-route-id="@goal.Id" method="post" onsubmit="return confirm('Bu hedefi silmek istediğinizden emin misiniz?');">
                                    <button type="submit" class="btn btn-sm btn-link text-danger p-0 border-0">
                                        <i class="fa-solid fa-trash-can"></i>
                                    </button>
                                </form>
                            </div>
                            
                            <div class="card-body px-3 pt-2">
                                <div class="text-muted small mb-3">Hedef Tarihi: @goal.TargetDate.ToString("dd.MM.yyyy")</div>
                                
                                <div class="d-flex justify-content-between align-items-center mb-1">
                                    <span class="small fw-semibold text-muted">İlerleme Oranı</span>
                                    <span class="small fw-bold">@goal.ProgressPercentage%</span>
                                </div>
                                <div class="progress mb-3" style="height: 10px; background-color: var(--border-color);">
                                    <div class="progress-bar bg-success" role="progressbar" style="width: @(goal.ProgressPercentage)%; border-radius: 5px;" aria-valuenow="@goal.ProgressPercentage" aria-valuemin="0" aria-valuemax="100"></div>
                                </div>

                                <div class="d-flex justify-content-between small text-muted mb-4">
                                    <div>Biriken: <span class="fw-bold text-success">@goal.CurrentAmount.ToString("C2")</span></div>
                                    <div>Hedef: <span class="fw-bold text-main">@goal.TargetAmount.ToString("C2")</span></div>
                                </div>
                            </div>
                        </div>

                        <!-- Alt Kısım: Bütçe Ekleme Formu -->
                        <div class="card-footer bg-light border-top p-3">
                            <form asp-action="AddFunds" asp-route-id="@goal.Id" method="post">
                                <div class="input-group input-group-sm">
                                    <input type="number" step="0.01" name="amount" class="form-control" placeholder="Birikim Ekle (₺)" required />
                                    <button class="btn btn-primary btn-sm fw-semibold" type="submit">
                                        <i class="fa-solid fa-piggy-bank me-1"></i>Para Ekle
                                    </button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12">
                <div class="card text-center py-5">
                    <div class="card-body">
                        <i class="fa-solid fa-bullseye fa-4x text-muted mb-3"></i>
                        <h3>Henüz Birikim Hedefi Belirlemediniz</h3>
                        <p class="text-muted max-width-md mx-auto mb-4">
                            Geleceğiniz için finansal hedefler koyarak birikim yapmaya başlayın.
                        </p>
                        <a asp-action="Create" class="btn btn-primary fw-semibold px-4">
                            <i class="fa-solid fa-plus me-2"></i>Hemen İlk Hedefini Koy
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>
</div>
