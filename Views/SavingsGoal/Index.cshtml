@model IEnumerable<PennyWise.Models.SavingsGoal>

@{
    ViewData["Title"] = "Birikim Kasaları";
    
    var activeCount = Model.Count();
    var totalSaved = Model.Sum(g => g.CurrentAmount);
    var totalTarget = Model.Sum(g => g.TargetAmount);
}

<div class="container-fluid px-0">
    <!-- Üst Başlık ve Yeni Kasa Oluşturma -->
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4 pb-3 border-bottom gap-3">
        <div>
            <span class="text-muted text-uppercase fw-bold tracking-wider small" style="font-size: 0.75rem; letter-spacing: 0.05em;">Birikim Hedefleri</span>
            <h1 class="h2 mb-1">Birikim Kasaları</h1>
            <p class="text-muted mb-0 small">Gelecek hedefleriniz için kumbaralar tanımlayarak bütçenizden para biriktirin.</p>
        </div>
        <div>
            <a asp-action="Create" class="btn btn-primary">
                <i class="fa-solid fa-plus"></i> Yeni Birikim Kasası Ekle
            </a>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show mb-4" role="alert">
            <i class="fa-solid fa-circle-check me-2"></i>@TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show mb-4" role="alert">
            <i class="fa-solid fa-circle-exclamation me-2"></i>@TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <!-- Kasa Metrikleri -->
    <div class="row g-3 mb-4">
        <!-- Aktif Kasalar -->
        <div class="col-md-4">
            <div class="card p-3 border-start border-4 border-primary">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <div class="text-muted small fw-semibold uppercase tracking-wider mb-1" style="font-size: 0.75rem;">Aktif Kasa Sayısı</div>
                        <div class="h3 mb-0 text-primary fw-bold">@activeCount Kasa</div>
                    </div>
                    <div class="p-2 bg-primary-subtle text-primary rounded-circle" style="width: 40px; height: 40px; display: flex; align-items: center; justify-content: center;">
                        <i class="fa-solid fa-vault"></i>
                    </div>
                </div>
            </div>
        </div>

        <!-- Toplam Birikim -->
        <div class="col-md-4">
            <div class="card p-3 border-start border-4 border-success">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <div class="text-muted small fw-semibold uppercase tracking-wider mb-1" style="font-size: 0.75rem;">Kasadaki Toplam Birikim</div>
                        <div class="h3 mb-0 text-success fw-bold">@totalSaved.ToString("C2")</div>
                    </div>
                    <div class="p-2 bg-success-subtle text-success rounded-circle" style="width: 40px; height: 40px; display: flex; align-items: center; justify-content: center;">
                        <i class="fa-solid fa-piggy-bank"></i>
                    </div>
                </div>
            </div>
        </div>

        <!-- Toplam Hedeflenen -->
        <div class="col-md-4">
            <div class="card p-3 border-start border-4 border-info">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <div class="text-muted small fw-semibold uppercase tracking-wider mb-1" style="font-size: 0.75rem;">Toplam Hedef Tutarı</div>
                        <div class="h3 mb-0 text-info fw-bold">@totalTarget.ToString("C2")</div>
                    </div>
                    <div class="p-2 bg-info-subtle text-info rounded-circle" style="width: 40px; height: 40px; display: flex; align-items: center; justify-content: center;">
                        <i class="fa-solid fa-bullseye"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Kasalar Listesi Grid -->
    <div class="row g-4">
        @if (Model.Any())
        {
            @foreach (var goal in Model)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="card h-100 d-flex flex-column justify-content-between">
                        <div>
                            <div class="card-header d-flex justify-content-between align-items-start border-0 pb-0 bg-transparent pt-3 px-3">
                                <h5 class="fw-bold mb-0 text-dark">
                                    <i class="fa-solid fa-piggy-bank text-primary me-2"></i>@goal.Title
                                </h5>
                                <div class="d-flex gap-2">
                                    <a asp-action="Edit" asp-route-id="@goal.Id" class="btn btn-sm btn-link text-primary p-0 border-0" title="Düzenle">
                                        <i class="fa-solid fa-pen-to-square"></i>
                                    </a>
                                    <form asp-action="Delete" asp-route-id="@goal.Id" method="post" class="d-inline" onsubmit="return confirm('Bu hedefi silmek istediğinizden emin misiniz?');">
                                        <button type="submit" class="btn btn-sm btn-link text-danger p-0 border-0" title="Sil">
                                            <i class="fa-solid fa-trash-can"></i>
                                        </button>
                                    </form>
                                </div>
                            </div>
                            
                            <div class="card-body px-3 pt-2">
                                <div class="text-muted small mb-3">Vade Hedefi: @goal.TargetDate.ToString("dd.MM.yyyy")</div>
                                
                                <div class="d-flex justify-content-between align-items-center mb-1">
                                    <span class="small fw-semibold text-muted">Kasa Doluluk Durumu</span>
                                    <span class="small fw-bold text-dark">%@goal.ProgressPercentage</span>
                                </div>
                                <div class="progress mb-3" style="height: 10px; background-color: var(--border-color);">
                                    <div class="progress-bar bg-success" role="progressbar" style="width: @(goal.ProgressPercentage.ToString("0.0", System.Globalization.CultureInfo.InvariantCulture))%; border-radius: 5px;" aria-valuenow="@goal.ProgressPercentage.ToString("0.0", System.Globalization.CultureInfo.InvariantCulture)" aria-valuemin="0" aria-valuemax="100"></div>
                                </div>

                                <div class="d-flex justify-content-between small text-muted">
                                    <div>Mevcut Bakiye: <br/><span class="fw-bold text-success" style="font-size: 0.95rem;">@goal.CurrentAmount.ToString("C2")</span></div>
                                    <div class="text-end">Hedef Tutar: <br/><span class="fw-bold text-dark" style="font-size: 0.95rem;">@goal.TargetAmount.ToString("C2")</span></div>
                                </div>
                            </div>
                        </div>

                        <!-- Alt Kısım: Bütçe Ekleme Formu -->
                        <div class="card-footer bg-light border-top p-3">
                            <form asp-action="AddFunds" asp-route-id="@goal.Id" method="post">
                                <div class="input-group">
                                    <input type="number" step="0.01" min="0.01" name="amount" class="form-control form-control-sm" placeholder="Miktar (₺)" required />
                                    <button class="btn btn-primary btn-sm fw-semibold" type="submit">
                                        <i class="fa-solid fa-plus-circle"></i> Kasaya Para Yatır
                                    </button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12">
                <div class="card text-center py-5 shadow-sm">
                    <div class="card-body">
                        <i class="fa-solid fa-vault fa-4x text-muted mb-3 opacity-50"></i>
                        <h3 class="fw-bold">Aktif Birikim Kasanız Bulunmuyor</h3>
                        <p class="text-muted max-width-md mx-auto mb-4 small">
                            Kumbaralar oluşturarak hayalleriniz için para biriktirmeye hemen başlayın.
                        </p>
                        <a asp-action="Create" class="btn btn-primary fw-semibold px-4">
                            <i class="fa-solid fa-plus me-2"></i>İlk Kasasını Oluştur
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>
</div>
