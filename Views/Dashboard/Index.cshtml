@model PennyWise.ViewModels.DashboardViewModel

@{
    ViewData["Title"] = "Finansal Kontrol Paneli";
    
    // Kullanıcı adı çıkarma
    var email = User.Identity?.Name ?? "";
    var username = !string.IsNullOrEmpty(email) ? email.Split('@')[0] : "Kullanıcı";
    var displayName = System.Globalization.CultureInfo.CurrentCulture.TextInfo.ToTitleCase(username);
}

<div class="container-fluid px-0">
    <!-- Üst Başlık ve Rapor İndirme -->
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4 pb-3 border-bottom gap-3">
        <div>
            <span class="text-muted text-uppercase fw-bold tracking-wider small" style="font-size: 0.75rem; letter-spacing: 0.05em;">Kişisel Portföy Özeti</span>
            <h1 class="h2 mb-1">Merhaba, @displayName</h1>
            <p class="text-muted mb-0 small">İçinde bulunduğunuz döneme ait varlık, gider ve bütçe planlarınız aşağıda listelenmiştir.</p>
        </div>
        <div class="d-flex gap-2">
            <a asp-action="PrintReport" target="_blank" class="btn btn-primary btn-sm px-3 py-2">
                <i class="fa-solid fa-file-pdf"></i> PDF Raporu İndir
            </a>
            <a asp-action="ExportTransactionsCsv" class="btn btn-outline-primary btn-sm px-3 py-2">
                <i class="fa-solid fa-file-csv"></i> Excel/CSV Aktar
            </a>
        </div>
    </div>

    <!-- Birincil Finansal Kartlar & Debit Card Gösterimi -->
    <div class="row g-4 mb-4">
        <!-- Sol: Dijital Banka Kartı Mockup (Debit Card) -->
        <div class="col-xl-4 col-lg-5">
            <div class="bank-card">
                <div class="bank-card-header">
                    <span class="bank-card-logo">
                        <i class="fa-solid fa-building-columns"></i> PENNYWISE
                    </span>
                    <span class="small fw-bold text-white-50" style="font-size: 0.65rem; letter-spacing: 0.1em;">DEBIT CARD</span>
                </div>
                <div class="bank-card-chip"></div>
                <div class="bank-card-body">
                    <div class="bank-card-label">Kalan Net Bakiye</div>
                    <div class="bank-card-balance">@Model.NetBalance.ToString("C2")</div>
                </div>
                <div class="bank-card-footer">
                    <span class="bank-card-holder">@displayName</span>
                    <span class="bank-card-number">**** **** **** @(DateTime.Now.Year)</span>
                </div>
            </div>
        </div>

        <!-- Sağ: Finansal Akışlar ve Hızlı Menü -->
        <div class="col-xl-8 col-lg-7">
            <div class="row g-3 h-100 flex-column justify-content-between">
                <!-- Gelir & Gider Akış Kartları -->
                <div class="col-12">
                    <div class="row g-3">
                        <!-- Toplam Gelir -->
                        <div class="col-sm-6">
                            <div class="card p-3 border-start border-4 border-success">
                                <div class="d-flex align-items-center justify-content-between">
                                    <div>
                                        <div class="text-muted small fw-semibold uppercase tracking-wider mb-1" style="font-size: 0.75rem;">Aylık Gelir Girişi</div>
                                        <div class="h3 mb-0 text-success fw-bold">@Model.TotalIncome.ToString("C2")</div>
                                    </div>
                                    <div class="p-3 bg-success-subtle text-success rounded-circle" style="width: 48px; height: 48px; display: flex; align-items: center; justify-content: center;">
                                        <i class="fa-solid fa-arrow-down-long"></i>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Toplam Gider -->
                        <div class="col-sm-6">
                            <div class="card p-3 border-start border-4 border-danger">
                                <div class="d-flex align-items-center justify-content-between">
                                    <div>
                                        <div class="text-muted small fw-semibold uppercase tracking-wider mb-1" style="font-size: 0.75rem;">Aylık Gider Çıkışı</div>
                                        <div class="h3 mb-0 text-danger fw-bold">@Model.TotalExpense.ToString("C2")</div>
                                    </div>
                                    <div class="p-3 bg-danger-subtle text-danger rounded-circle" style="width: 48px; height: 48px; display: flex; align-items: center; justify-content: center;">
                                        <i class="fa-solid fa-arrow-up-long"></i>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Hızlı İşlemler Grubu -->
                <div class="col-12">
                    <div class="card border-0 shadow-none bg-transparent">
                        <div class="card-header bg-transparent border-0 px-0 pb-2 pt-0">
                            <span class="fw-bold text-muted small text-uppercase tracking-wider" style="font-size: 0.75rem;">
                                <i class="fa-solid fa-bolt text-primary me-1"></i> Hızlı Bankacılık İşlemleri
                            </span>
                        </div>
                        <div class="card-body px-0 py-0">
                            <div class="row g-2">
                                <div class="col-6 col-sm-3">
                                    <a asp-controller="Transaction" asp-action="Create" class="btn btn-outline-primary w-100 py-3 d-flex flex-column gap-2 rounded-3 border">
                                        <i class="fa-solid fa-plus-circle fa-lg"></i>
                                        <span class="small fw-semibold" style="font-size: 0.8rem;">Yeni İşlem</span>
                                    </a>
                                </div>
                                <div class="col-6 col-sm-3">
                                    <a asp-controller="Bill" asp-action="Create" class="btn btn-outline-primary w-100 py-3 d-flex flex-column gap-2 rounded-3 border">
                                        <i class="fa-solid fa-receipt fa-lg"></i>
                                        <span class="small fw-semibold" style="font-size: 0.8rem;">Fatura Ekle</span>
                                    </a>
                                </div>
                                <div class="col-6 col-sm-3">
                                    <a asp-controller="SavingsGoal" asp-action="Create" class="btn btn-outline-primary w-100 py-3 d-flex flex-column gap-2 rounded-3 border">
                                        <i class="fa-solid fa-bullseye fa-lg"></i>
                                        <span class="small fw-semibold" style="font-size: 0.8rem;">Hedef Koy</span>
                                    </a>
                                </div>
                                <div class="col-6 col-sm-3">
                                    <a asp-controller="BudgetLimit" asp-action="Create" class="btn btn-outline-primary w-100 py-3 d-flex flex-column gap-2 rounded-3 border">
                                        <i class="fa-solid fa-gauge-high fa-lg"></i>
                                        <span class="small fw-semibold" style="font-size: 0.8rem;">Bütçe Limiti</span>
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Orta Bölüm: Grafikler ve Birikim Pockets (Vaults) -->
    <div class="row g-4 mb-4">
        <!-- Chart.js Gelir & Gider Dağılımları -->
        <div class="col-lg-7">
            <div class="card h-100">
                <div class="card-header border-bottom-0 py-3 bg-transparent">
                    <span class="fw-bold d-flex align-items-center gap-2">
                        <i class="fa-solid fa-chart-pie text-primary"></i> Varlık Dağılım Analizi
                    </span>
                </div>
                <div class="card-body py-2 d-flex align-items-center justify-content-center" style="min-height: 280px;">
                    <div class="row w-100">
                        <div class="col-6 d-flex flex-column align-items-center">
                            <span class="text-muted small fw-bold mb-2">Gider Dağılımı</span>
                            @if (Model.CategoryDistribution != null && Model.CategoryDistribution.Any())
                            {
                                <div style="position: relative; height:180px; width:100%">
                                    <canvas id="categoryChart"></canvas>
                                </div>
                            }
                            else
                            {
                                <div class="d-flex flex-column align-items-center justify-content-center h-100 text-center py-5">
                                    <i class="fa-solid fa-chart-pie fa-2x text-muted mb-2"></i>
                                    <p class="small text-muted mb-0">Gider Kaydı Yok</p>
                                </div>
                            }
                        </div>
                        <div class="col-6 d-flex flex-column align-items-center">
                            <span class="text-muted small fw-bold mb-2">Gelir Dağılımı</span>
                            @if (Model.IncomeDistribution != null && Model.IncomeDistribution.Any())
                            {
                                <div style="position: relative; height:180px; width:100%">
                                    <canvas id="incomeChart"></canvas>
                                </div>
                            }
                            else
                            {
                                <div class="d-flex flex-column align-items-center justify-content-center h-100 text-center py-5">
                                    <i class="fa-solid fa-chart-pie fa-2x text-muted mb-2"></i>
                                    <p class="small text-muted mb-0">Gelir Kaydı Yok</p>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Birikim Kasaları (Revolut/Vaults Benzeri) -->
        <div class="col-lg-5">
            <div class="card h-100">
                <div class="card-header d-flex justify-content-between align-items-center py-3 bg-transparent">
                    <span class="fw-bold d-flex align-items-center gap-2">
                        <i class="fa-solid fa-vault text-primary"></i> Birikim Kasalarınız (Kasa)
                    </span>
                    <a asp-controller="SavingsGoal" asp-action="Index" class="btn btn-sm btn-outline-primary border-0 py-1 px-2">Yönet</a>
                </div>
                <div class="card-body">
                    @if (Model.SavingsGoals.Any())
                    {
                        <div class="d-flex flex-column gap-3">
                            @foreach (var goal in Model.SavingsGoals.Take(3))
                            {
                                <div class="p-2 border rounded-3 bg-light-subtle">
                                    <div class="d-flex justify-content-between align-items-center mb-1">
                                        <span class="fw-semibold text-dark small"><i class="fa-solid fa-piggy-bank text-primary me-2"></i>@goal.Title</span>
                                        <span class="small fw-bold">@goal.ProgressPercentage%</span>
                                    </div>
                                    <div class="progress mb-2" style="height: 6px; background-color: var(--border-color);">
                                        <div class="progress-bar bg-primary" role="progressbar" style="width: @(goal.ProgressPercentage.ToString("0.0", System.Globalization.CultureInfo.InvariantCulture))%; border-radius: 4px;" aria-valuenow="@goal.ProgressPercentage.ToString("0.0", System.Globalization.CultureInfo.InvariantCulture)" aria-valuemin="0" aria-valuemax="100"></div>
                                    </div>
                                    <div class="d-flex justify-content-between text-muted" style="font-size: 0.75rem;">
                                        <span>@goal.CurrentAmount.ToString("C0") / @goal.TargetAmount.ToString("C0")</span>
                                        <span>Hedef: @goal.TargetDate.ToString("dd.MM.yyyy")</span>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="text-center text-muted py-5 d-flex flex-column align-items-center justify-content-center">
                            <i class="fa-solid fa-piggy-bank fa-3x text-muted mb-3"></i>
                            <p class="small mb-1 fw-bold text-dark">Aktif Kasa Bulunmuyor</p>
                            <p class="small mb-3 text-muted" style="font-size: 0.8rem;">Gelecek planlarınız için hemen bir birikim kasası oluşturun.</p>
                            <a asp-controller="SavingsGoal" asp-action="Create" class="btn btn-sm btn-primary px-3 rounded-pill shadow-sm">Kasa Oluştur</a>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Alt Bölüm: Yaklaşan Faturalar Ledger Ekstresi -->
    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-header d-flex justify-content-between align-items-center py-3 bg-transparent">
                    <span class="fw-bold d-flex align-items-center gap-2">
                        <i class="fa-solid fa-receipt text-primary"></i> Yaklaşan Fatura Ödemeleri
                    </span>
                    <a asp-controller="Bill" asp-action="Index" class="btn btn-sm btn-outline-primary border-0 py-1 px-2">Tümünü Listele</a>
                </div>
                <div class="card-body p-0">
                    @if (Model.UpcomingBills.Any())
                    {
                        <div class="table-responsive">
                            <table class="table align-middle">
                                <thead>
                                    <tr>
                                        <th>Fatura Adı</th>
                                        <th>Kategori</th>
                                        <th>Son Ödeme Tarihi</th>
                                        <th>Tutar</th>
                                        <th class="text-end">İşlem</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var bill in Model.UpcomingBills)
                                    {
                                        var daysRemaining = (bill.DueDate - DateTime.UtcNow).Days;
                                        <tr>
                                            <td class="fw-bold text-dark">@bill.Title</td>
                                            <td><span class="badge bg-light text-dark border">@bill.Category?.Name</span></td>
                                            <td>
                                                <span class="small @(daysRemaining <= 3 ? "text-danger fw-bold" : "text-muted")">
                                                    @bill.DueDate.ToString("dd.MM.yyyy")
                                                    @if (daysRemaining >= 0 && daysRemaining <= 3)
                                                    {
                                                        <text> (@daysRemaining gün kaldı!)</text>
                                                    }
                                                </span>
                                            </td>
                                            <td class="fw-bold text-danger">@bill.Amount.ToString("C2")</td>
                                            <td class="text-end">
                                                <form asp-controller="Bill" asp-action="Pay" asp-route-id="@bill.Id" method="post" class="d-inline">
                                                    <button type="submit" class="btn btn-sm btn-outline-primary py-1 px-3">
                                                        <i class="fa-solid fa-credit-card"></i> Öde
                                                    </button>
                                                </form>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="text-center text-muted py-5 d-flex flex-column align-items-center justify-content-center">
                            <i class="fa-solid fa-circle-check fa-3x text-success mb-3"></i>
                            <p class="small mb-1 fw-bold text-dark">Faturanız Bulunmuyor</p>
                            <p class="small mb-3 text-muted" style="font-size: 0.8rem;">Yakın zamanda ödenmesi gereken bir faturanız kalmadı.</p>
                            <a asp-controller="Bill" asp-action="Create" class="btn btn-sm btn-primary px-3 rounded-pill shadow-sm">Fatura Ekle</a>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Chart.js Kütüphanesi & Banka Tasarım Konfigürasyonu -->
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
    document.addEventListener("DOMContentLoaded", function () {
        const chartOptions = {
            responsive: true,
            maintainAspectRatio: false,
            plugins: {
                legend: {
                    position: 'bottom',
                    labels: {
                        boxWidth: 8,
                        padding: 12,
                        font: {
                            family: "'Plus Jakarta Sans', sans-serif",
                            size: 10,
                            weight: '500'
                        }
                    }
                }
            },
            cutout: '72%'
        };

        @if (Model.CategoryDistribution != null && Model.CategoryDistribution.Any())
        {
            <text>
            var ctx = document.getElementById('categoryChart').getContext('2d');
            new Chart(ctx, {
                type: 'doughnut',
                data: {
                    labels: @Html.Raw(Json.Serialize(Model.CategoryDistribution.Select(c => c.CategoryName))),
                    datasets: [{
                        data: @Html.Raw(Json.Serialize(Model.CategoryDistribution.Select(c => c.TotalAmount))),
                        backgroundColor: ['#EF4444', '#F59E0B', '#8B5CF6', '#EC4899', '#6366F1', '#64748B'],
                        borderWidth: 2, 
                        borderColor: '#ffffff'
                    }]
                },
                options: chartOptions
            });
            </text>
        }

        @if (Model.IncomeDistribution != null && Model.IncomeDistribution.Any())
        {
            <text>
            var ctxIncome = document.getElementById('incomeChart').getContext('2d');
            new Chart(ctxIncome, {
                type: 'doughnut',
                data: {
                    labels: @Html.Raw(Json.Serialize(Model.IncomeDistribution.Select(c => c.CategoryName))),
                    datasets: [{
                        data: @Html.Raw(Json.Serialize(Model.IncomeDistribution.Select(c => c.TotalAmount))),
                        backgroundColor: ['#10B981', '#3B82F6', '#06B6D4', '#14B8A6', '#84CC16', '#64748B'],
                        borderWidth: 2, 
                        borderColor: '#ffffff'
                    }]
                },
                options: chartOptions
            });
            </text>
        }
    });
</script>
