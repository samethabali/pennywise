@model PennyWise.ViewModels.DashboardViewModel

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>PennyWise - Aylık Hesap Özeti</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.0/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <style>
        body {
            font-family: 'Inter', -apple-system, sans-serif;
            background-color: #ffffff;
            color: #1a1f36;
            padding: 40px;
        }
        .header-section {
            border-bottom: 2px solid #e3e8ee;
            padding-bottom: 20px;
            margin-bottom: 30px;
        }
        .statement-title {
            font-size: 24px;
            font-weight: 700;
            letter-spacing: -0.5px;
        }
        .summary-card {
            border: 1px solid #e3e8ee;
            border-radius: 8px;
            padding: 20px;
            background-color: #f7f9fc;
        }
        .table th {
            font-size: 11px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            color: #4f566b;
            font-weight: 600;
            border-bottom: 2px solid #e3e8ee;
        }
        .table td {
            font-size: 14px;
            padding: 12px;
            border-bottom: 1px solid #e3e8ee;
        }
        .print-only-actions {
            margin-bottom: 20px;
        }
        @@media print {
            .no-print {
                display: none !important;
            }
            body {
                padding: 0;
            }
        }
    </style>
</head>
<body>

    <!-- Yazdırma Kontrolleri (Ekran Görünümünde görünür, PDF'te gizlenir) -->
    <div class="container no-print mb-4">
        <div class="d-flex justify-content-between align-items-center bg-light p-3 border rounded">
            <span class="small text-muted"><i class="fa-solid fa-circle-info me-2"></i>Bu sayfa yazdırılmak ve PDF olarak kaydedilmek üzere özel olarak tasarlanmıştır.</span>
            <div class="d-flex gap-2">
                <a href="/Dashboard/Index" class="btn btn-outline-secondary btn-sm"><i class="fa-solid fa-chevron-left me-1"></i> Geri Dön</a>
                <button onclick="window.print()" class="btn btn-primary btn-sm fw-semibold"><i class="fa-solid fa-print me-1"></i> Yazdır / PDF Kaydet</button>
            </div>
        </div>
    </div>

    <div class="container" style="max-width: 850px;">
        <!-- Header -->
        <div class="d-flex justify-content-between align-items-center header-section">
            <div>
                <h1 class="statement-title mb-1"><i class="fa-solid fa-building-columns text-primary me-2"></i>PennyWise</h1>
                <span class="text-muted small">Resmi Aylık Finansal Hesap Özeti</span>
            </div>
            <div class="text-end">
                <div class="fw-bold">@DateTime.Now.ToString("MMMM yyyy")</div>
                <div class="text-muted small">Düzenlenme: @DateTime.Now.ToString("dd.MM.yyyy")</div>
            </div>
        </div>

        <!-- Özet Blokları -->
        <div class="row g-3 mb-4">
            <div class="col-4">
                <div class="summary-card text-center">
                    <div class="text-muted small mb-1">Toplam Gelir</div>
                    <div class="h4 mb-0 text-success fw-bold">@Model.TotalIncome.ToString("C2")</div>
                </div>
            </div>
            <div class="col-4">
                <div class="summary-card text-center">
                    <div class="text-muted small mb-1">Toplam Gider</div>
                    <div class="h4 mb-0 text-danger fw-bold">@Model.TotalExpense.ToString("C2")</div>
                </div>
            </div>
            <div class="col-4">
                <div class="summary-card text-center">
                    <div class="text-muted small mb-1">Net Durum</div>
                    <div class="h4 mb-0 fw-bold @(Model.NetBalance >= 0 ? "text-primary" : "text-warning")">
                        @Model.NetBalance.ToString("C2")
                    </div>
                </div>
            </div>
        </div>

        <!-- Dağılımlar ve Grafikler -->
        <div class="row g-4 mb-4">
            <div class="col-6">
                <h5 class="fw-bold mb-3">Kategori Dağılımı</h5>
                @if (Model.CategoryDistribution.Any())
                {
                    <table class="table">
                        <thead>
                            <tr>
                                <th>Kategori</th>
                                <th class="text-end">Harcanan Tutar</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.CategoryDistribution)
                            {
                                <tr>
                                    <td class="fw-semibold">@item.CategoryName</td>
                                    <td class="text-end text-danger fw-semibold">@item.TotalAmount.ToString("C2")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <p class="text-muted small">Bu aya ait harcama bulunmamaktadır.</p>
                }
            </div>

            <!-- Sağ Taraf: Grafik Alanı (Yazdırma sırasında Chart.js mükemmel çalışır) -->
            <div class="col-6 d-flex align-items-center justify-content-center">
                @if (Model.CategoryDistribution.Any())
                {
                    <div style="width: 230px; height: 230px;">
                        <canvas id="pdfChart"></canvas>
                    </div>
                }
            </div>
        </div>

        <!-- Yaklaşan Faturalar Listesi -->
        @if (Model.UpcomingBills.Any())
        {
            <div class="mb-4">
                <h5 class="fw-bold mb-3">Planlanmış Gelecek Ödemeler</h5>
                <table class="table">
                    <thead>
                        <tr>
                            <th>Fatura</th>
                            <th>Kategori</th>
                            <th>Son Ödeme Tarihi</th>
                            <th class="text-end">Tutar</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var bill in Model.UpcomingBills)
                        {
                            <tr>
                                <td class="fw-semibold">@bill.Title</td>
                                <td><span class="badge bg-light text-dark border">@bill.Category?.Name</span></td>
                                <td class="text-muted">@bill.DueDate.ToString("dd.MM.yyyy")</td>
                                <td class="text-end text-danger fw-bold">@bill.Amount.ToString("C2")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }

        <!-- Alt Not -->
        <div class="text-center mt-5 pt-4 border-top text-muted small">
            Bu belge PennyWise Finansal Yönetim Sistemi tarafından elektronik olarak üretilmiştir.
        </div>
    </div>

    <!-- Chart.js Kütüphanesi -->
    @if (Model.CategoryDistribution.Any())
    {
        <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
        <script>
            document.addEventListener("DOMContentLoaded", function () {
                var ctx = document.getElementById('pdfChart').getContext('2d');
                var myChart = new Chart(ctx, {
                    type: 'doughnut',
                    data: {
                        labels: @Html.Raw(Json.Serialize(Model.CategoryDistribution.Select(c => c.CategoryName))),
                        datasets: [{
                            data: @Html.Raw(Json.Serialize(Model.CategoryDistribution.Select(c => c.TotalAmount))),
                            backgroundColor: [
                                '#635BFF', '#00D924', '#FF2F4C', '#FF9F43', '#20B2AA', '#7B68EE'
                            ],
                            borderWidth: 2,
                            borderColor: '#ffffff'
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: {
                            legend: {
                                position: 'bottom',
                                labels: {
                                    font: { size: 10 },
                                    boxWidth: 10
                                }
                            }
                        },
                        cutout: '60%'
                    }
                });

                // Sayfa yüklenip grafik çizildikten yarım saniye sonra yazdırma ekranını otomatik aç!
                setTimeout(function() {
                    window.print();
                }, 600);
            });
        </script>
    }
    else
    {
        <script>
            document.addEventListener("DOMContentLoaded", function () {
                setTimeout(function() {
                    window.print();
                }, 300);
            });
        </script>
    }
</body>
</html>
