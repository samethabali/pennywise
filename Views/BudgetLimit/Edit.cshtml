@model PennyWise.Models.BudgetLimit

@{
    ViewData["Title"] = "Bütçe Limitini Düzenle";
}

<div class="row justify-content-center">
    <div class="col-md-6 col-lg-5">
        <div class="card shadow-sm">
            <div class="card-header py-3 bg-transparent">
                <div class="d-flex align-items-center gap-2">
                    <i class="fa-solid fa-pen text-primary fa-lg"></i>
                    <h5 class="mb-0 fw-bold">Bütçe Limitini Düzenle</h5>
                </div>
            </div>
            <div class="card-body">
                <p class="text-muted small mb-4">Seçtiğiniz gider kategorisi için belirlenen aylık harcama limitini güncelleyin.</p>

                <form asp-action="Edit" method="post" id="budgetLimitForm">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3" role="alert"></div>
                    <input type="hidden" asp-for="Id" />

                    <!-- Kategori Seçimi -->
                    <div class="mb-3">
                        <label asp-for="CategoryId" class="form-label text-dark fw-semibold">Gider Kategorisi</label>
                        <select asp-for="CategoryId" class="form-select" asp-items="ViewBag.Categories">
                            <option value="">-- Kategori Seçin --</option>
                        </select>
                        <span asp-validation-for="CategoryId" class="text-danger small"></span>
                    </div>

                    <!-- Tutar -->
                    <div class="mb-3">
                        <label asp-for="LimitAmount" class="form-label text-dark fw-semibold">Aylık Limit Tutarı</label>
                        <div class="input-group">
                            <input asp-for="LimitAmount" type="number" step="0.01" min="0.01" class="form-control" placeholder="0.00" required
                                   oninput="this.value = this.value < 0 ? 0 : this.value" />
                            <span class="input-group-text bg-light border-start-0">₺</span>
                        </div>
                        <span asp-validation-for="LimitAmount" class="text-danger small"></span>
                        <div class="form-text text-muted" style="font-size: 0.75rem;">Bu gider kalemi için ayda en fazla harcayacağınız tutarı belirleyin.</div>
                    </div>

                    <!-- Ay ve Yıl -->
                    <div class="row mb-4">
                        <div class="col-md-6">
                            <label asp-for="Month" class="form-label text-dark fw-semibold">Dönem Ayı</label>
                            <select asp-for="Month" class="form-select">
                                <option value="1">Ocak</option>
                                <option value="2">Şubat</option>
                                <option value="3">Mart</option>
                                <option value="4">Nisan</option>
                                <option value="5">Mayıs</option>
                                <option value="6">Haziran</option>
                                <option value="7">Temmuz</option>
                                <option value="8">Ağustos</option>
                                <option value="9">Eylül</option>
                                <option value="10">Ekim</option>
                                <option value="11">Kasım</option>
                                <option value="12">Aralık</option>
                            </select>
                            <span asp-validation-for="Month" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Year" class="form-label text-dark fw-semibold">Dönem Yılı</label>
                            <input asp-for="Year" type="number" min="2024" max="2035" class="form-control" required />
                            <span asp-validation-for="Year" class="text-danger small"></span>
                        </div>
                    </div>

                    <!-- Butonlar -->
                    <div class="d-flex gap-2 justify-content-end border-top pt-3">
                        <a asp-action="Index" class="btn btn-outline-primary px-3">İptal</a>
                        <button type="submit" class="btn btn-primary px-4 fw-semibold">
                            <i class="fa-solid fa-floppy-disk"></i> Değişiklikleri Kaydet
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var limitInput = document.getElementById('LimitAmount');
            if (limitInput) {
                limitInput.addEventListener('input', function () {
                    if (parseFloat(this.value) < 0) {
                        this.value = '';
                        this.setCustomValidity('Limit tutarı negatif olamaz!');
                        this.reportValidity();
                    } else {
                        this.setCustomValidity('');
                    }
                });

                limitInput.addEventListener('keydown', function (e) {
                    if (e.key === '-' || e.key === 'e') {
                        e.preventDefault();
                    }
                });
            }
        });
    </script>
}
