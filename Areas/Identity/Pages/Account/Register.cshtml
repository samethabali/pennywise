@page
@model RegisterModel
@{
    ViewData["Title"] = "Kayıt Ol";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-5">
        <div class="card p-4 shadow-lg border-0" style="background: var(--surface-light); border-radius: 1rem;">
            <div class="text-center mb-4">
                <i class="fa-solid fa-user-plus fa-3x text-primary mb-3"></i>
                <h2 style="font-weight:700;">Hesap Oluştur</h2>
                <p class="text-muted">Aramıza katılarak finansal özgürlüğüne ilk adımı at.</p>
            </div>
            
            <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3" role="alert"></div>
                
                <div class="form-floating mb-3">
                    <input asp-for="Input.Email" class="form-control bg-dark text-white border-secondary" autocomplete="username" aria-required="true" placeholder="isim@ornek.com" />
                    <label asp-for="Input.Email" class="text-muted">E-posta Adresi</label>
                    <span asp-validation-for="Input.Email" class="text-danger"></span>
                </div>
                
                <div class="form-floating mb-3">
                    <input asp-for="Input.Password" class="form-control bg-dark text-white border-secondary" autocomplete="new-password" aria-required="true" placeholder="şifre" />
                    <label asp-for="Input.Password" class="text-muted">Şifre</label>
                    <span asp-validation-for="Input.Password" class="text-danger"></span>
                </div>
                
                <div class="form-floating mb-4">
                    <input asp-for="Input.ConfirmPassword" class="form-control bg-dark text-white border-secondary" autocomplete="new-password" aria-required="true" placeholder="şifre tekrar" />
                    <label asp-for="Input.ConfirmPassword" class="text-muted">Şifreyi Onayla</label>
                    <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
                </div>
                
                <button id="registerSubmit" type="submit" class="w-100 btn btn-lg btn-success rounded-pill fw-bold">Kayıt Ol <i class="fa-solid fa-check ms-2"></i></button>
                
                <div class="text-center mt-4 pt-3 border-top border-secondary">
                    <p class="mb-0">
                        Zaten bir hesabın var mı? <a asp-page="./Login" asp-route-returnUrl="@Model.ReturnUrl" class="text-decoration-none text-info fw-bold">Giriş Yap</a>
                    </p>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
