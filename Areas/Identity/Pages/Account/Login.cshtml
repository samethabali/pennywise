@page
@model LoginModel

@{
    ViewData["Title"] = "Giriş Yap";
    ViewData["HideNavbarLinks"] = true;
}

<div class="login-bg-wrapper">
    <div class="neon-lines">
        <div class="neon-line nl-1"></div>
        <div class="neon-line nl-2"></div>
        <div class="neon-line nl-3"></div>
        <div class="neon-line nl-4"></div>
    </div>
</div>

<div class="row justify-content-center align-items-center min-vh-100 m-0 position-relative" style="z-index: 10;">
    <div class="col-md-5 col-lg-4 px-4">
        <div class="card card-login p-4 shadow-lg border-0">
            <div class="text-center mb-4">
                <div class="login-3d-icon mb-3">
                    <i class="fa-solid fa-shield-halved"></i>
                    <i class="fa-solid fa-user-lock"></i>
                </div>
                <h2 class="login-title">Hoş Geldin</h2>
                <p class="login-subtitle">Geleceğin finansal özgürlüğüne giriş yap.</p>
            </div>
            
            <section>
                <form id="account" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3" role="alert"></div>
                    
                    <div class="form-floating mb-3">
                        <input asp-for="Input.Email" class="form-control bg-dark text-white border-secondary" autocomplete="username" aria-required="true" placeholder="isim@ornek.com" style="border-radius: 12px; background-color: rgba(0, 0, 0, 0.4) !important; border-color: rgba(59, 130, 246, 0.3) !important;" />
                        <label asp-for="Input.Email" class="text-muted">E-posta Adresi</label>
                        <span asp-validation-for="Input.Email" class="text-danger"></span>
                    </div>
                    
                    <div class="form-floating mb-3">
                        <input asp-for="Input.Password" class="form-control bg-dark text-white border-secondary" autocomplete="current-password" aria-required="true" placeholder="şifre" style="border-radius: 12px; background-color: rgba(0, 0, 0, 0.4) !important; border-color: rgba(59, 130, 246, 0.3) !important;" />
                        <label asp-for="Input.Password" class="text-muted">Şifre</label>
                        <span asp-validation-for="Input.Password" class="text-danger"></span>
                    </div>
                    
                    <div class="form-check mb-4">
                        <input class="form-check-input" asp-for="Input.RememberMe" style="background-color: rgba(0, 0, 0, 0.4); border-color: rgba(59, 130, 246, 0.4);" />
                        <label asp-for="Input.RememberMe" class="form-check-label text-light small">
                            Beni Hatırla
                        </label>
                    </div>
                    
                    <button id="login-submit" type="submit" class="w-100 btn btn-lg btn-login-neon">Giriş Yap <i class="fa-solid fa-arrow-right ms-2"></i></button>
                    
                    <div class="text-center mt-4 pt-3 border-top border-secondary" style="border-color: rgba(255, 255, 255, 0.1) !important;">
                        <p class="mb-2">
                            <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl" class="link-neon-cyan">Hesabın yok mu? Hemen Kayıt Ol</a>
                        </p>
                        <p class="mb-0">
                            <a id="forgot-password" asp-page="./ForgotPassword" class="link-neon-cyan-muted">Şifreni mi unuttun?</a>
                        </p>
                    </div>
                </form>
            </section>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
